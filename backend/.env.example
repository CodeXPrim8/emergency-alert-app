PORT=3000
NODE_ENV=development

# --- Supabase (browser client — safe to expose publishable key) ---
SUPABASE_URL=https://kenrtchvapvgjjompogc.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_d1W_oKAZd9iGTXl6PJSEWQ_hEkJDyj7
# Next.js-style names also work:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase Postgres (backend — keeps users & alerts permanently) ---
# Project Settings → Database → Connection string → Transaction pooler (port 6543)
# DATABASE_URL=postgresql://postgres.kenrtchvapvgjjompogc:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
USE_SQLITE=true

# Local SQLite path (when USE_SQLITE=true and no DATABASE_URL)
# SQLITE_PATH=./data/emergency_alert.db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=365d

# RSA keys (generate with: node src/utils/generateKeys.js)
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# Firebase (optional - for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Nearby user radius in meters (2000-5000 per spec)
NEARBY_RADIUS_METERS=3000

# Grace period for false alarm cancellation (seconds)
ALERT_CANCEL_GRACE_SECONDS=30

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
