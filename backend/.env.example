PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/emergency_alert

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=365d

# RSA keys (generate with: node src/utils/generateKeys.js)
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# Firebase (optional - for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Nearby user radius in meters (2000-5000 per spec)
NEARBY_RADIUS_METERS=3000

# Grace period for false alarm cancellation (seconds)
ALERT_CANCEL_GRACE_SECONDS=30

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
